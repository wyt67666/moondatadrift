name = "33046/moondatadrift"

version = "0.1.0"

readme = "README.md"

repository = ""

license = "Apache-2.0"

keywords = [ "moonbit", "mlops", "data-drift", "monitoring" ]

preferred_target = "wasm-gc"

description = "A MoonBit library and CLI for comparing baseline and current tabular data for drift, missingness, PSI, and KS-like analysis."
